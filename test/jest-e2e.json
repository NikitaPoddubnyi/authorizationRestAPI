{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
  "^src/(.*)$": "<rootDir>/src/$1",
  "^src/generated/prisma/(.*)\\.js$": "<rootDir>/src/generated/prisma/$1",
  "^\\.\\/(.*)\\.js$": "./$1"
},
  "moduleDirectories": ["node_modules", "<rootDir>", "<rootDir>/src/generated"],
  "transformIgnorePatterns": [
    "/node_modules/(?!@prisma)"
  ]
}